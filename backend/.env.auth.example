# Supabase project config
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT for MetaMask session token issued by backend
WALLET_AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
WALLET_AUTH_TOKEN_TTL=7d
WALLET_CHALLENGE_TTL_MINUTES=10

# Optional branding / OAuth callback defaults
AUTH_APP_NAME=Eth Cannes UZH26
GOOGLE_REDIRECT_TO=http://localhost:5173/auth/callback
WALLET_AUTH_DOMAIN=localhost
WALLET_AUTH_URI=http://localhost:3000
